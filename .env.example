# =============================================================================
# DEMO TREN SEPOLIA (MetaMask + tai khoan cua ban)
# =============================================================================
# 1) RPC Sepolia — dung URL THAT (khong de YOUR_...)
#    Nhanh, khong can dang ky: (co the cham / gioi han) public endpoint
RPC_URL=https://rpc.sepolia.org
#    Hoac Infura: https://sepolia.infura.io/v3/<PROJECT_ID> (lay tai infura.io)
#    Hoac Alchemy: https://eth-sepolia.g.alchemy.com/v2/<API_KEY>
#
# 2) PRIVATE_KEY = private key VI MetaMask (64 ky tu hex, co the co 0x)
#    Dung cho backend ky giao dich CREATOR (store-hash, revoke, ...) — khong phai de User tao DID.
#    User tao DID bang MetaMask tren trang User (goi chain truc tiep + /api/did/confirm-create).
#    KHONG phai Infura Project ID (32 ky tu) — Infura chi dung trong RPC_URL phia tren.
# CANH BAO: Khong commit .env len Git. Khong dung key mainnet / tien that lon.
PRIVATE_KEY=
#
# CHAIN_ID trong .env chi de ghi nho; backend lay dia chi contract tu shared/constants.py
CHAIN_ID=11155111

# Dia chi contract (tuy chon): de trong — backend doc tu shared/constants.py
# Chi can sua neu ban muon override (it dung):
# DID_REGISTRY_ADDRESS=0x...
# SOULBOUND_ADDRESS=0x...

# IPFS Pinata (https://app.pinata.cloud) — bat buoc cho upload file
IPFS_API_KEY=your_pinata_api_key
IPFS_SECRET_KEY=your_pinata_secret_key
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# NFT orchestrator (python nft-integration/integration.py): mac dinh dung PRIVATE_KEY
# ISSUER_PRIVATE_KEY=

# BACKEND
BACKEND_PORT=8000
SQLITE_DB_PATH=./backend/ssi.db
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://127.0.0.1:5173,http://127.0.0.1:8000

# =============================================================================
# LOCAL ANVIL (tuy chon) — comment block Sepolia tren, mo block duoi
# =============================================================================
# RPC_URL=http://127.0.0.1:8545
# PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# CHAIN_ID=31337
